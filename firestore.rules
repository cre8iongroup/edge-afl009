
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isInternal(userId) {
      return getRole(userId) == 'internal';
    }

    // Path: /users/{userId}
    // Description: Stores user profiles.
    match /users/{userId} {
      // READ: Users can read their own profile. Internal users can read any profile.
      allow get: if isSignedIn() && (isOwner(userId) || isInternal(request.auth.uid));
      allow list: if isSignedIn() && isInternal(request.auth.uid);

      // CREATE: A user can create their own profile upon sign-up.
      // The incoming resource must have the owner's UID.
      allow create: if isSignedIn() && isOwner(userId);

      // UPDATE: A user can update their own profile.
      // An internal user can update anyone's profile (e.g., to change a role).
      // Role changes are restricted to internal users.
      allow update: if isSignedIn() && (isOwner(userId) && request.resource.data.role == resource.data.role || isInternal(request.auth.uid));

      // DELETE: Only internal users can delete user profiles.
      allow delete: if isSignedIn() && isInternal(request.auth.uid);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
