rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the requesting user is the owner of the document.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Gets the role of the requesting user.
    function requestorRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.get('role', 'regular') : 'regular';
    }

    // Checks if the requesting user is an admin or internal user.
    function isInternalOrAdmin() {
      return isSignedIn() && requestorRole() in ['internal', 'admin'];
    }

    // --- Path Rules ---

    match /users/{userId} {
      // Allow read if owner, or if requestor is internal/admin
      allow get: if isSignedIn() && (isOwner(userId) || isInternalOrAdmin());
      // Allow list if requestor is internal/admin
      allow list: if isSignedIn() && isInternalOrAdmin();
      // Allow create if owner
      allow create: if isSignedIn() && isOwner(userId);
      // Allow update if owner (and not changing role), or if requestor is internal/admin
      allow update: if isSignedIn() && (isOwner(userId) && request.resource.data.role == resource.data.role || isInternalOrAdmin());
      // Allow delete if requestor is internal/admin
      allow delete: if isSignedIn() && isInternalOrAdmin();
    }

    match /submissions/{submissionId} {
      // Allow create for any signed in user
      allow create: if isSignedIn();
      // Allow read if owner or requestor is internal/admin
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isInternalOrAdmin());
      // Allow list if requestor is internal/admin OR owner
      allow list: if isSignedIn() && (isInternalOrAdmin() || resource.data.userId == request.auth.uid);
      // Allow update/delete if owner or requestor is internal/admin
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isInternalOrAdmin());
    }

    // Allow users to manage their own subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
