rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the requesting user is the owner of the document.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Gets the role of the requesting user.
    function requestorRole() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.get('role', 'regular') : 'regular';
    }

    // Checks if the requesting user is an admin or internal user.
    function isInternalOrAdmin() {
      return isSignedIn() && requestorRole() in ['internal', 'admin'];
    }

    // Checks if the requesting user is a client.
    function isClient() {
      return isSignedIn() && requestorRole() == 'client';
    }

    // --- Path Rules ---

    match /users/{userId} {
      // Allow read if owner, or if requestor is internal/admin
      allow get: if isSignedIn() && (isOwner(userId) || isInternalOrAdmin());
      // Allow list if requestor is internal/admin, or client (for /review submitter attribution)
      allow list: if isSignedIn() && (isInternalOrAdmin() || isClient());
      // Allow create if owner
      allow create: if isSignedIn() && isOwner(userId);
      // Allow update if owner (and not changing role), or if requestor is internal/admin
      allow update: if isSignedIn() && (isOwner(userId) && request.resource.data.role == resource.data.role || isInternalOrAdmin());
      // Allow delete if requestor is internal/admin
      allow delete: if isSignedIn() && isInternalOrAdmin();
    }

    // Checks if the requesting user's email is in the document's authorizedEmails array.
    // Used to grant delegate read/write access without transferring ownership.
    function isAuthorizedEmail() {
      return isSignedIn()
        && 'authorizedEmails' in resource.data
        && request.auth.token.email in resource.data.authorizedEmails;
    }

    match /submissions/{submissionId} {
      // Allow create for any signed in user
      allow create: if isSignedIn();
      // Allow get if owner, delegate (authorizedEmails), internal/admin, or client
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAuthorizedEmail() ||
        isInternalOrAdmin() ||
        isClient()
      );
      // Allow list if internal/admin, client (for /review page), or owner
      allow list: if isSignedIn() && (isInternalOrAdmin() || isClient() || resource.data.userId == request.auth.uid);
      // Allow update/delete if owner, delegate, internal/admin, or client
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAuthorizedEmail() ||
        isInternalOrAdmin() ||
        isClient()
      );
    }

    // Allow users to manage their own subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Workshop inventory and other app config — readable by any signed-in user,
    // updatable by any signed-in user (capacity enforcement is done in app-layer transactions)
    match /config/{docId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
