/**
 * Core Philosophy:
 * This ruleset implements a robust security model combining Role-Based Access
 * Control (RBAC) with strict User Ownership. The primary goal is to ensure
 * that users can only access and manage their own data, while granting
 * administrative users read-access to all data for oversight and write-access
 * to global configuration collections like 'roles'.
 *
 * Data Structure:
 * The data is organized hierarchically with a user-centric approach. All data
 * created by a user, such as workshop submissions and notifications, is stored
 * in subcollections under that user's document in the top-level '/users'
 * collection (e.g., /users/{userId}/workshopSubmissions/{submissionId}). This
 * structure makes ownership-based rules simple and performant. Global data,
 * such as roles, is stored in a top-level collection.
 *
 * Key Security Decisions:
 * - Default Deny: All paths are closed by default. Access is only granted
 *   through explicit 'allow' rules.
 * - Strict Ownership: Users have full control over their own data located in
 *   subcollections under their user document. They cannot access, list, or
 *   modify data belonging to other users.
 * - Admin Privilege: A special 'admin' role is defined. Users with this role
 *   have read-only access to all data across the database and write access to
 *   the global '/roles' collection. This prevents admins from impersonating
 *   users by creating or modifying their data.
 * - No User Listing: To protect user privacy, listing documents in the '/users'
 *   collection is disabled for all non-administrative users.
 * - Server-Side Creation for Notifications: Client-side creation of
 *   notifications is disabled to ensure they are only generated by trusted
 *   backend processes.
 *
 * Denormalization for Authorization:
 * This ruleset relies on denormalization for efficient and secure authorization.
 * - The user's roleId is stored directly on their '/users/{userId}' document.
 *   This allows the isAdmin() function to perform a single, fast 'get' call
 *   to determine a user's role without needing to query other collections.
 * - For the '/feedbackQueues' collection, it is critical that each document
 *   contains a denormalized 'submissionOwnerId' field, copying the userId from
 *   the related workshop submission. This allows for a direct ownership check
 *   without performing a slow and costly cross-collection 'get' on the
 *   submission document.
 *
 * Structural Segregation:
 * The separation of user-specific data into subcollections under '/users/{userId}'
 * is a clear example of structural segregation. This ensures that a query for
 * a user's workshop submissions will never accidentally contain data from
 * another user, simplifying both security rules and client-side code.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * Used to verify document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the document being written to already exists.
     * Essential for securing all update and delete operations.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Returns true if the authenticated user has the 'admin' role.
     * This requires reading the user's own profile document.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == 'admin';
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Manages user profiles. Users can create and manage their own
     *   profile. Admins have read access to all profiles and can delete them.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own user profile document.
     * @allow (get) An authenticated user can get their own user profile document.
     * @deny (list) A non-admin user cannot list all user profiles in the database.
     * @deny (update) A user cannot update another user's profile.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Defines the available roles in the system (e.g., admin, client).
     *   This data is considered public for any signed-in user to read, but can
     *   only be modified by administrators.
     * @path /roles/{roleId}
     * @allow (get, list) Any authenticated user can read the list of available roles.
     * @deny (create) A non-admin user cannot create a new role.
     * @principle Provides public read access for configuration data while restricting writes to admins.
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Stores workshop submissions created by users. Access is strictly
     *   limited to the user who created the submission. Admins have read-only access.
     * @path /users/{userId}/workshopSubmissions/{workshopSubmissionId}
     * @allow (create) A user can create a new workshop submission for themselves.
     * @allow (get, list) A user can read their own workshop submissions.
     * @deny (update) A user cannot update another user's submission.
     * @deny (delete) A user cannot delete another user's submission.
     * @principle Enforces document ownership within a user-specific subcollection.
     */
    match /users/{userId}/workshopSubmissions/{workshopSubmissionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description Stores user-specific notifications. Users can read, update (e.g., mark as read),
     *   and delete their own notifications. Creation is disallowed from the client to
     *   ensure notifications are only generated by trusted backend services.
     * @path /users/{userId}/notifications/{notificationId}
     * @allow (get, list) A user can read their own notifications.
     * @deny (create) No user, including the owner, can create notifications from the client.
     * @principle Restricts access to owner and disables client-side creation for system-generated data.
     */
    match /users/{userId}/notifications/{notificationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if false;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description Stores AI feedback requests. Access is granted to admins and the
     *   original owner of the workshop submission this feedback is for.
     * @path /feedbackQueues/{feedbackQueueId}
     * @allow (create) A user can create a feedback request, correctly linking their own UID.
     * @allow (get) An admin or the submission owner can read a feedback request.
     * @deny (list) A non-admin user cannot list all feedback requests in the system.
     * @deny (update) A user cannot modify a feedback request for another user's submission.
     * @principle Relational security based on denormalized ownership data.
     */
    match /feedbackQueues/{feedbackQueueId} {
      // CRITICAL: This rule requires that each FeedbackQueue document contains a
      // 'submissionOwnerId' field that stores the UID of the user who created the
      // associated workshop submission. This denormalization is essential for security.
      allow get: if (isOwner(resource.data.submissionOwnerId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(request.resource.data.submissionOwnerId);
      allow update: if (isOwner(resource.data.submissionOwnerId) || isAdmin()) && isExistingDoc();
      allow delete: if (isOwner(resource.data.submissionOwnerId) || isAdmin()) && isExistingDoc();
    }
  }
}