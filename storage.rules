rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Headshots ────────────────────────────────────────────────────────────
    // Any authenticated user can read headshots (needed for admin views).
    // Writes are restricted to authenticated users uploading valid image files
    // within the 10 MB size limit enforced in the UI.
    match /headshots/{sessionId}/{presenterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size <= 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
    }

  }
}
