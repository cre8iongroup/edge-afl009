rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Headshots ────────────────────────────────────────────────────────────
    // Any authenticated user can read headshots (needed for admin views).
    // Writes are restricted to authenticated users uploading valid image files
    // within the 10 MB size limit enforced in the UI.
    match /headshots/{sessionId}/{presenterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size <= 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
    }

    // ─── Scenic brand assets ──────────────────────────────────────────────────
    // Partners upload logo and brand guidelines keyed by their UID.
    // Any authenticated user can read (design team access).
    // Writes scoped to the owning partner (uid path segment must match auth.uid).
    // MIME type is not enforced here — vector formats (SVG, EPS, AI) have
    // inconsistent MIME types; extension validation is handled in the UI.
    match /scenic/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size <= 50 * 1024 * 1024;
    }

  }
}
